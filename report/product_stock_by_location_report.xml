<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_product_stock_by_location_document">
        <t t-call="web.external_layout">
            <div class="page">
                <h2>Stock by Location</h2>
                <t t-set="products" t-value="docs.mapped('product_id')"/>
                <t t-foreach="products" t-as="product">
                    <h4>
                        <span t-esc="product.display_name"/>
                        <t t-if="product.barcode">
                            <span> — Barcode: </span>
                            <span t-esc="product.barcode"/>
                        </t>
                        <t t-if="product.default_code">
                            <span> — Ref: </span>
                            <span t-esc="product.default_code"/>
                        </t>
                    </h4>
                    <t t-set="lines" t-value="docs.filtered(lambda l: l.product_id.id == product.id)"/>
                    <table class="table table-sm o_main_table" style="margin-bottom: 24px;">
                        <thead>
                            <tr>
                                <th>Location</th>
                                <th class="text-end">Quantity</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="lines" t-as="line">
                                <td><span t-esc="line.location_id.complete_name"/></td>
                                <td class="text-end"><span t-esc="line.quantity"/></td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td><strong>Total</strong></td>
                                <td class="text-end"><strong t-esc="sum(lines.mapped('quantity'))"/></td>
                            </tr>
                        </tfoot>
                    </table>
                </t>
            </div>
        </t>
    </template>

    <template id="report_product_stock_by_location">
        <t t-call="web.html_container">
            <t t-call="stock_barcode_location_report.report_product_stock_by_location_document"/>
        </t>
    </template>

    <record id="action_report_product_stock_by_location" model="ir.actions.report">
        <field name="name">Stock by Location</field>
        <field name="model">product.stock.by.location.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_barcode_location_report.report_product_stock_by_location</field>
        <field name="report_file">stock_barcode_location_report.report_product_stock_by_location</field>
        <field name="binding_model_id" ref="model_product_stock_by_location_report"/>
        <field name="binding_type">report</field>
        <field name="print_report_name">'Stock by Location'</field>
    </record>

</odoo>
