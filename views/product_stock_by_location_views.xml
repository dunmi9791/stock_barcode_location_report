<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_product_stock_by_location_list" model="ir.ui.view">
        <field name="name">product.stock.by.location.report.list</field>
        <field name="model">product.stock.by.location.report</field>
        <field name="arch" type="xml">
            <list string="Stock by Location" create="false" edit="false" delete="false">
                <field name="barcode"/>
                <field name="product_id"/>
                <field name="default_code" string="Internal Reference"/>
                <field name="location_id"/>
                <field name="warehouse_id"/>
                <field name="quantity" sum="Total Quantity"/>
                <field name="uom_id"/>
            </list>
        </field>
    </record>

    <record id="view_product_stock_by_location_pivot" model="ir.ui.view">
        <field name="name">product.stock.by.location.report.pivot</field>
        <field name="model">product.stock.by.location.report</field>
        <field name="arch" type="xml">
            <pivot string="Stock by Location" display_quantity="true">
                <field name="product_id" type="row"/>
                <field name="location_id" type="col"/>
                <field name="quantity" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_product_stock_by_location_search" model="ir.ui.view">
        <field name="name">product.stock.by.location.report.search</field>
        <field name="model">product.stock.by.location.report</field>
        <field name="arch" type="xml">
            <search string="Stock by Location">
                <field name="product_id"/>
                <field name="barcode"/>
                <field name="default_code" string="Internal Reference"/>
                <field name="location_id"/>
                <field name="warehouse_id"/>
                <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                <filter string="Location" name="group_location" context="{'group_by': 'location_id'}"/>
                <filter string="Warehouse" name="group_warehouse" context="{'group_by': 'warehouse_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_product_stock_by_location_report" model="ir.actions.act_window">
        <field name="name">Stock by Location</field>
        <field name="res_model">product.stock.by.location.report</field>
        <field name="view_mode">pivot,list</field>
        <field name="search_view_id" ref="view_product_stock_by_location_search"/>
        <field name="context">{'search_default_group_product': 1}</field>
    </record>

    <menuitem id="menu_product_stock_by_location_report"
              name="Stock by Location"
              parent="stock.menu_warehouse_report"
              action="action_product_stock_by_location_report"
              sequence="20"/>

</odoo>
